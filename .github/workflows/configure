#!/bin/bash
# This is a simple template for a configure script.
# Customize it according to your project's build and configuration needs.

# Define configuration variables
CC=gcc
CFLAGS="-Wall -Wextra"
LDFLAGS="-lm"
SRCDIRS="srcc srcp cmplr"
OBJDIR="obj"
BINDIR="bin"

# Define source files
SOURCES=""

for dir in $SRCDIRS; do
  SOURCES="$SOURCES $(find $dir -name '*.c')"
done

# Define build target
TARGET="build.elf"

# Run the build process
echo "Configuring the project..."
echo "CC: $CC"
echo "CFLAGS: $CFLAGS"
echo "LDFLAGS: $LDFLAGS"
echo "SOURCES: $SOURCES"
echo "TARGET: $TARGET"

# Create the object directory
mkdir -p $OBJDIR

# Build the project
for src in $SOURCES; do
  obj="${OBJDIR}/${src##*/.c}.o"
  mkdir -p $(dirname $obj)
  $CC $CFLAGS -c $src -o $obj
done

# Link the project
echo "Linking the project..."
mkdir -p $(dirname $TARGET)
$CC -o $TARGET $OBJDIR/*.o $LDFLAGS

# Provide instructions for the user
echo "Build completed. The binary is located at ./$TARGET."

# End of the script
